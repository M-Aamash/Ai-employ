# AI Employee Environment Configuration
# ======================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# ======================================
# Gmail API Configuration
# ======================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8080

# Path to Gmail credentials JSON file (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json

# Path where OAuth token will be stored (auto-generated)
GMAIL_TOKEN_PATH=./credentials/gmail_token.json

# ======================================
# Claude Code Configuration
# ======================================
# Claude API key (if using API directly)
# CLAUDE_API_KEY=your_claude_api_key_here

# Preferred Claude model
CLAUDE_MODEL=opus

# ======================================
# WhatsApp Web Configuration (Optional)
# ======================================
# Path to store WhatsApp session data
WHATSAPP_SESSION_PATH=./credentials/whatsapp_session

# Keywords that trigger urgent action
WHATSAPP_URGENT_KEYWORDS=urgent,asap,invoice,payment,help

# ======================================
# Bank Integration Configuration (Optional)
# ======================================
# Bank API credentials (if using bank API)
# BANK_API_TOKEN=your_bank_api_token_here
# BANK_API_URL=your_bank_api_url_here

# ======================================
# System Configuration
# ======================================
# Path to Obsidian vault
VAULT_PATH=./AI_Employee_Vault

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Check interval for watchers (seconds)
WATCHER_CHECK_INTERVAL=120

# Maximum Claude Code execution time (seconds)
CLAUDE_TIMEOUT=300

# Maximum iterations for Ralph Wiggum loop
MAX_RALPH_ITERATIONS=10

# ======================================
# Development Mode
# ======================================
# Set to 'true' to prevent any real external actions
DRY_RUN=false

# Maximum actions per hour (rate limiting)
MAX_EMAILS_PER_HOUR=10
MAX_PAYMENTS_PER_HOUR=3
MAX_SOCIAL_POSTS_PER_HOUR=5

# ======================================
# Notification Configuration (Optional)
# ======================================
# Email to send system notifications
# ADMIN_EMAIL=your_email@example.com

# Webhook URL for notifications (e.g., Slack, Discord)
# NOTIFICATION_WEBHOOK_URL=your_webhook_url_here

# ======================================
# Security Notes
# ======================================
# 1. Never commit .env file to git
# 2. Rotate credentials monthly
# 3. Use separate test credentials for development
# 4. Store production credentials in a secrets manager
